{
  "__inputs": [
    {
      "name": "DS_NETWATCHM",
      "label": "NetWatchM",
      "description": "Infinity datasource pointing at NetWatchM inventory.json",
      "type": "datasource",
      "pluginId": "yesoreyeram-infinity-datasource",
      "pluginName": "Infinity"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "yesoreyeram-infinity-datasource", "name": "Infinity", "version": "2.0.0" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "table", "name": "Table", "version": "" },
    { "type": "panel", "id": "barchart", "name": "Bar chart", "version": "" },
    { "type": "panel", "id": "piechart", "name": "Pie chart", "version": "" }
  ],
  "annotations": { "list": [] },
  "description": "NetWatchM network inventory — powered by Infinity datasource",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Total Devices",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "blue", "mode": "fixed" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] }
        },
        "overrides": []
      },
      "datasource": { "type": "yesoreyeram-infinity-datasource", "uid": "${DS_NETWATCHM}" },
      "targets": [
        {
          "refId": "A",
          "type": "json",
          "source": "url",
          "url": "http://localhost:8765/inventory.json",
          "parser": "backend",
          "root_selector": "",
          "columns": [],
          "filters": [],
          "summaryExpression": "count($)"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "HIGH Threat",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "red", "mode": "fixed" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }] }
        },
        "overrides": []
      },
      "datasource": { "type": "yesoreyeram-infinity-datasource", "uid": "${DS_NETWATCHM}" },
      "targets": [
        {
          "refId": "A",
          "type": "json",
          "source": "url",
          "url": "http://localhost:8765/inventory.json",
          "parser": "backend",
          "root_selector": "",
          "columns": [],
          "filters": [{ "field": "threat_level", "operator": "equals", "value": "HIGH" }],
          "summaryExpression": "count($)"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "MEDIUM Threat",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "orange", "mode": "fixed" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "orange", "value": null }] }
        },
        "overrides": []
      },
      "datasource": { "type": "yesoreyeram-infinity-datasource", "uid": "${DS_NETWATCHM}" },
      "targets": [
        {
          "refId": "A",
          "type": "json",
          "source": "url",
          "url": "http://localhost:8765/inventory.json",
          "parser": "backend",
          "root_selector": "",
          "columns": [],
          "filters": [{ "field": "threat_level", "operator": "equals", "value": "MEDIUM" }],
          "summaryExpression": "count($)"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "LOW Threat",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "green", "mode": "fixed" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        },
        "overrides": []
      },
      "datasource": { "type": "yesoreyeram-infinity-datasource", "uid": "${DS_NETWATCHM}" },
      "targets": [
        {
          "refId": "A",
          "type": "json",
          "source": "url",
          "url": "http://localhost:8765/inventory.json",
          "parser": "backend",
          "root_selector": "",
          "columns": [],
          "filters": [{ "field": "threat_level", "operator": "equals", "value": "LOW" }],
          "summaryExpression": "count($)"
        }
      ]
    },
    {
      "id": 5,
      "type": "piechart",
      "title": "Threat Distribution",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 0 },
      "options": {
        "displayLabels": ["name", "value"],
        "legend": { "displayMode": "table", "placement": "right", "values": ["value", "percent"] },
        "pieType": "donut",
        "tooltip": { "mode": "single" }
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          { "matcher": { "id": "byName", "options": "HIGH" },   "properties": [{ "id": "color", "value": { "fixedColor": "#F85149", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "MEDIUM" }, "properties": [{ "id": "color", "value": { "fixedColor": "#D29922", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "LOW" },    "properties": [{ "id": "color", "value": { "fixedColor": "#3FB950", "mode": "fixed" } }] }
        ]
      },
      "datasource": { "type": "yesoreyeram-infinity-datasource", "uid": "${DS_NETWATCHM}" },
      "targets": [
        {
          "refId": "A",
          "type": "json",
          "source": "url",
          "url": "http://localhost:8765/inventory.json",
          "parser": "backend",
          "root_selector": "",
          "columns": [
            { "selector": "threat_level", "text": "Threat", "type": "string" }
          ],
          "filters": [],
          "group_by": [{ "column": "Threat" }],
          "summaryExpression": "count($)"
        }
      ]
    },
    {
      "id": 6,
      "type": "table",
      "title": "Device Inventory",
      "gridPos": { "h": 14, "w": 24, "x": 0, "y": 8 },
      "options": {
        "cellHeight": "sm",
        "footer": { "countRows": false, "fields": "", "reducer": ["sum"], "show": false },
        "showHeader": true,
        "sortBy": [{ "desc": true, "displayName": "Threat" }]
      },
      "fieldConfig": {
        "defaults": { "custom": { "align": "auto", "cellOptions": { "type": "auto" } } },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Threat" },
            "properties": [
              {
                "id": "custom.cellOptions",
                "value": { "type": "color-text" }
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "green",  "value": null },
                    { "color": "orange", "value": 2 },
                    { "color": "red",    "value": 3 }
                  ]
                }
              },
              {
                "id": "mappings",
                "value": [
                  { "type": "value", "options": { "LOW":      { "color": "green",  "index": 0 } } },
                  { "type": "value", "options": { "MEDIUM":   { "color": "orange", "index": 1 } } },
                  { "type": "value", "options": { "HIGH":     { "color": "red",    "index": 2 } } },
                  { "type": "value", "options": { "CRITICAL": { "color": "purple", "index": 3 } } }
                ]
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Sent (B)" },
            "properties": [{ "id": "unit", "value": "bytes" }, { "id": "displayName", "value": "Sent" }]
          },
          {
            "matcher": { "id": "byName", "options": "Received (B)" },
            "properties": [{ "id": "unit", "value": "bytes" }, { "id": "displayName", "value": "Received" }]
          }
        ]
      },
      "datasource": { "type": "yesoreyeram-infinity-datasource", "uid": "${DS_NETWATCHM}" },
      "targets": [
        {
          "refId": "A",
          "type": "json",
          "source": "url",
          "url": "http://localhost:8765/inventory.json",
          "parser": "backend",
          "root_selector": "",
          "columns": [
            { "selector": "ip",             "text": "IP",           "type": "string" },
            { "selector": "hostname",       "text": "Hostname",     "type": "string" },
            { "selector": "mac",            "text": "MAC",          "type": "string" },
            { "selector": "vendor",         "text": "Vendor",       "type": "string" },
            { "selector": "threat_level",   "text": "Threat",       "type": "string" },
            { "selector": "bytes_sent",     "text": "Sent (B)",     "type": "number" },
            { "selector": "bytes_received", "text": "Received (B)", "type": "number" },
            { "selector": "last_seen",      "text": "Last Seen",    "type": "timestamp_epoch_s" }
          ],
          "filters": []
        }
      ]
    },
    {
      "id": 7,
      "type": "barchart",
      "title": "Top Devices by Traffic (Sent)",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 22 },
      "options": {
        "barRadius": 0.05,
        "barWidth": 0.7,
        "colorByField": "Sent (B)",
        "groupWidth": 0.7,
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "orientation": "horizontal",
        "stacking": "none",
        "tooltip": { "mode": "single" },
        "xTickLabelMaxLength": 0,
        "xTickLabelRotation": 0
      },
      "fieldConfig": {
        "defaults": { "unit": "bytes", "color": { "mode": "palette-classic" } },
        "overrides": []
      },
      "datasource": { "type": "yesoreyeram-infinity-datasource", "uid": "${DS_NETWATCHM}" },
      "targets": [
        {
          "refId": "A",
          "type": "json",
          "source": "url",
          "url": "http://localhost:8765/inventory.json",
          "parser": "backend",
          "root_selector": "",
          "columns": [
            { "selector": "ip",         "text": "IP",       "type": "string" },
            { "selector": "bytes_sent", "text": "Sent (B)", "type": "number" }
          ],
          "filters": []
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["netwatchm", "network", "security"],
  "templating": { "list": [] },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "NetWatchM Network Monitor",
  "uid": "netwatchm-inventory",
  "version": 1
}
