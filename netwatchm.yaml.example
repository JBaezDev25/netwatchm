interface: auto          # or exact name e.g. enp6s0
baseline_period: 300     # seconds to learn "known" IPs before alerting on new ones

thresholds:
  port_scan:
    ports_per_window: 15
    window_seconds: 10
  brute_force:
    attempts_per_window: 10
    window_seconds: 30
    ports: [22, 3389, 21, 3306, 5900]
  exfiltration:
    bytes_per_window: 10485760   # 10 MB
    window_seconds: 60
  new_ip:
    enabled: true
  adult_domain:
    enabled: true
    # list_url: ...  # Steven Black porn-only list (default)
    alert_window_seconds: 3600
    extra_domains: []  # add custom adult domains here
  tracker_domain:
    enabled: true
    # list_url: ...  # Steven Black unified adware+malware list (default)
    alert_window_seconds: 3600
    extra_domains: []  # e.g. [api.segment.io, www.google-analytics.com]
  malware_domain:
    enabled: true
    # list_url: https://urlhaus.abuse.ch/downloads/hostfile/  (default)
    refresh_hours: 6
    alert_window_seconds: 1800
    extra_domains: []  # add custom IOC domains here
  dns_tunneling:
    enabled: true
    queries_per_window: 10        # suspicious DNS queries needed to fire
    window_seconds: 60
    min_label_length: 30          # leftmost label longer than this = suspicious
    min_query_length: 60          # full FQDN longer than this = suspicious
    entropy_threshold: 4.0        # Shannon entropy of leftmost label
    alert_window_seconds: 600
  beaconing:
    enabled: true
    min_contacts: 6               # contacts to a single dst before scoring
    min_interval_seconds: 30      # ignore intervals shorter than this
    max_interval_seconds: 3600
    max_jitter_ratio: 0.15        # CoV; below = regular beacon
    window_seconds: 7200          # how long contact history is kept
    alert_window_seconds: 1800

alerts:
  terminal: true
  log:
    enabled: true
    path: /var/log/netwatchm/netwatchm.log
    max_bytes: 10485760    # 10 MB
    backup_count: 5
  sound:
    enabled: true
    file: assets/alert.wav
    min_level: HIGH        # only play for HIGH or CRITICAL
  email:
    enabled: false
    smtp_host: smtp.gmail.com
    smtp_port: 587
    username: jbaez120@gmail.com
    password: ""           # set via NETWATCHM_EMAIL_PASSWORD env var
    recipient: jbaez120@gmail.com
    min_level: HIGH
    cooldown_seconds: 3600  # min gap between emails per (alert_type, device) pair
  ntfy:
    enabled: false
    server: https://ntfy.sh  # or http://localhost:2586 for self-hosted
    topic: ""                # your ntfy topic name (keep secret for basic privacy)
    # token: ""              # set via NETWATCHM_NTFY_TOKEN for private topics
    min_level: CRITICAL      # real-time push only for genuine threats (CRITICAL)
    cooldown_seconds: 300    # min gap between notifications for same alert type
    exclude_types:           # never pushed in real time (still detected + stored)
      - BEACONING            #   beacon patterns are low-signal — see the agent digest
  event_store:
    retention_hours: 72      # hours to keep alert events in database (default: 72)
  forensics:                 # auto incident response: pcap + threat-intel on alert
    enabled: false           # opt-in; needs tshark running as the service
    min_level: HIGH          # open a case for alerts at/above this level
    cooldown_seconds: 600    # per-IP gap between cases (avoid case floods)
    capture_enabled: true    # short-burst pcap of the offending IP
    capture_seconds: 10      # capture duration (bounded; also packet-capped)
    capture_interface: auto  # "auto" reuses the monitor interface
    capture_dir: /var/lib/netwatchm/forensics
    db_path: /var/lib/netwatchm/forensics.db
    retention_days: 15       # prune incidents older than this
    intel_enabled: true      # reputation lookups on external IPs
    greynoise: true          # community endpoint — no key needed
    abuseipdb: true          # needs NETWATCHM_ABUSEIPDB_KEY env var
    virustotal: true         # needs NETWATCHM_VT_KEY env var
    intel_timeout: 8         # per-provider HTTP timeout (seconds)
    # API keys are read from env vars ONLY, never from this file:
    #   NETWATCHM_ABUSEIPDB_KEY, NETWATCHM_VT_KEY, NETWATCHM_GREYNOISE_KEY

inventory:
  enabled: true
  persist_interval: 60    # seconds between auto-saves to inventory.json
  dns_timeout: 2          # seconds before giving up on reverse DNS lookup
  dns_cache_ttl: 300      # seconds to cache failed lookups
  export_dir: .           # default directory for CSV exports (. = cwd)
  local_networks:         # only track IPs in these ranges; empty = track all
    - 192.168.1.0/24
  arp_scan:
    enabled: true
    interval: 300         # seconds between active scans
    network: auto         # "auto" = --localnet, or explicit CIDR e.g. 192.168.1.0/24

whitelist:
  enabled: true
  ips:
    - 192.168.1.1          # gateway/router
    - 192.168.1.180        # this machine
    - 107.170.66.130       # Twingate relay (DigitalOcean NJ)
    - 162.243.34.191       # Twingate relay (DigitalOcean NJ)
    - 167.99.149.114       # Twingate relay (DigitalOcean NJ)

detector_whitelist:
  # Suppress specific alert types from specific IPs only.
  # Does NOT suppress other alert types from these IPs.
  # Key = alert type (PORT_SCAN, BRUTE_FORCE, EXFILTRATION, NEW_IP,
  #                   TOR_EXIT, ADULT_DOMAIN, TRACKER_DOMAIN, DATA_HOG,
  #                   MALWARE_DOMAIN, DNS_TUNNELING, BEACONING)
  # Value = list of src_ip addresses to suppress for that type
  PORT_SCAN: []          # e.g. [192.168.1.180]  — suppress port scan from your own machine
  BRUTE_FORCE: []        # e.g. [192.168.1.50]   — suppress brute force from a scanner
  TRACKER_DOMAIN: []     # e.g. [192.168.1.10]   — suppress tracker alerts from a specific device
  MALWARE_DOMAIN: []     # rarely needed — only suppress for confirmed false positives
  DNS_TUNNELING: []      # e.g. [192.168.1.10]   — suppress for known long-DNS apps (some VPNs)
  BEACONING: []          # e.g. [192.168.1.10]   — suppress for legit periodic clients (NTP, telemetry)

agent:
  # Autonomous decision loop. Two modes:
  #
  #   dry_run: true  (Phase 1)   — agent ONLY observes; rationale and tool
  #                                calls are written to agent_actions.db,
  #                                but action tools are blocked at dispatch.
  #                                Run for a few days and review the audit
  #                                log before promoting to live.
  #
  #   dry_run: false (Phase 2)   — agent may also add/remove whitelist
  #                                entries (TTL-bounded, side-car file at
  #                                /var/lib/netwatchm/agent_whitelist.json,
  #                                hot-reloaded into alert_dispatch_loop),
  #                                suppress alert types (TTL-bounded), run
  #                                nmap/deep-inspect scans, and send ntfy
  #                                notifications with one-tap rollback
  #                                action buttons. Hard guardrails enforce
  #                                rate caps and refuse dangerous actions
  #                                regardless of what the LLM says.
  enabled: false                          # set true after ollama is reachable
  dry_run: true                           # flip to false ONLY after audit review
  model: mistral:latest                   # 7B non-thinking tool-capable model — fastest on CPU
  ollama_base_url: http://127.0.0.1:11434
  interval_seconds: 300                   # 5 min between ticks
  timeout_seconds: 600                    # per LLM call (CPU inference is slow)
  temperature: 0.2
  context_hours_back: 4                   # how far back to pull events each tick
  context_max_events: 50
  context_prompt_char_cap: 16000          # cap on JSON-serialised context in prompt
  max_tool_hops: 4                        # max tool round-trips per tick

  # --- Notification mode -------------------------------------------------
  #   reactive (default) — decide every interval_seconds; may push per tick.
  #   digest             — stay quiet, then push ONE categorized summary
  #                        every digest_interval_days listing each threat
  #                        category + a recommended mitigation. Real-time
  #                        CRITICAL pushes still come from the ntfy handler
  #                        above (min_level: CRITICAL); beacons never push.
  #                        Requires alerts.ntfy.enabled + a topic.
  mode: digest
  digest_interval_days: 5                  # how often the digest is pushed
  digest_lookback_days: 5                  # window each digest summarizes
  digest_max_events: 2000                  # cap on events scanned per digest
  digest_exclude_types:                    # left out of the digest entirely
    - BEACONING

retention:
  # 15-day uniform retention sweep (Session 29).
  #
  # In-process daily task that:
  #   - prunes agent_actions.db rows older than retention_days
  #   - compacts rolled-back / expired entries out of
  #     agent_whitelist.json + agent_blocks.json
  #
  # Existing pruners (events.db, flows.db, flow-history.db) keep using
  # their own retention knobs — those defaults are also 15 days now.
  #
  # Text-log retention is handled by /etc/logrotate.d/netwatchm
  # (installed via scripts/install-log-retention.sh) so it works even
  # when the netwatchm service is down. Do not duplicate it here.
  enabled: true
  retention_days: 15
  interval_seconds: 86400                 # 24 h between sweeps
