interface: auto          # or exact name e.g. enp6s0
baseline_period: 300     # seconds to learn "known" IPs before alerting on new ones

thresholds:
  port_scan:
    ports_per_window: 15
    window_seconds: 10
  brute_force:
    attempts_per_window: 10
    window_seconds: 30
    ports: [22, 3389, 21, 3306, 5900]
  exfiltration:
    bytes_per_window: 10485760   # 10 MB
    window_seconds: 60
  new_ip:
    enabled: true
  adult_domain:
    enabled: true
    # list_url: ...  # Steven Black porn-only list (default)
    alert_window_seconds: 3600
    extra_domains: []  # add custom adult domains here
  tracker_domain:
    enabled: true
    # list_url: ...  # Steven Black unified adware+malware list (default)
    alert_window_seconds: 3600
    extra_domains: []  # e.g. [api.segment.io, www.google-analytics.com]
  malware_domain:
    enabled: true
    # list_url: https://urlhaus.abuse.ch/downloads/hostfile/  (default)
    refresh_hours: 6
    alert_window_seconds: 1800
    extra_domains: []  # add custom IOC domains here
  dns_tunneling:
    enabled: true
    queries_per_window: 10        # suspicious DNS queries needed to fire
    window_seconds: 60
    min_label_length: 30          # leftmost label longer than this = suspicious
    min_query_length: 60          # full FQDN longer than this = suspicious
    entropy_threshold: 4.0        # Shannon entropy of leftmost label
    alert_window_seconds: 600
  beaconing:
    enabled: true
    min_contacts: 6               # contacts to a single dst before scoring
    min_interval_seconds: 30      # ignore intervals shorter than this
    max_interval_seconds: 3600
    max_jitter_ratio: 0.15        # CoV; below = regular beacon
    window_seconds: 7200          # how long contact history is kept
    alert_window_seconds: 1800

alerts:
  terminal: true
  log:
    enabled: true
    path: /var/log/netwatchm/netwatchm.log
    max_bytes: 10485760    # 10 MB
    backup_count: 5
  sound:
    enabled: true
    file: assets/alert.wav
    min_level: HIGH        # only play for HIGH or CRITICAL
  email:
    enabled: false
    smtp_host: smtp.gmail.com
    smtp_port: 587
    username: jbaez120@gmail.com
    password: ""           # set via NETWATCHM_EMAIL_PASSWORD env var
    recipient: jbaez120@gmail.com
    min_level: HIGH
    cooldown_seconds: 3600  # min gap between emails per (alert_type, device) pair
  ntfy:
    enabled: false
    server: https://ntfy.sh  # or http://localhost:2586 for self-hosted
    topic: ""                # your ntfy topic name (keep secret for basic privacy)
    # token: ""              # set via NETWATCHM_NTFY_TOKEN for private topics
    min_level: HIGH
    cooldown_seconds: 300    # min gap between notifications for same alert type
  event_store:
    retention_hours: 72      # hours to keep alert events in database (default: 72)

inventory:
  enabled: true
  persist_interval: 60    # seconds between auto-saves to inventory.json
  dns_timeout: 2          # seconds before giving up on reverse DNS lookup
  dns_cache_ttl: 300      # seconds to cache failed lookups
  export_dir: .           # default directory for CSV exports (. = cwd)
  local_networks:         # only track IPs in these ranges; empty = track all
    - 192.168.1.0/24
  arp_scan:
    enabled: true
    interval: 300         # seconds between active scans
    network: auto         # "auto" = --localnet, or explicit CIDR e.g. 192.168.1.0/24

whitelist:
  enabled: true
  ips:
    - 192.168.1.1          # gateway/router
    - 192.168.1.180        # this machine
    - 107.170.66.130       # Twingate relay (DigitalOcean NJ)
    - 162.243.34.191       # Twingate relay (DigitalOcean NJ)
    - 167.99.149.114       # Twingate relay (DigitalOcean NJ)

detector_whitelist:
  # Suppress specific alert types from specific IPs only.
  # Does NOT suppress other alert types from these IPs.
  # Key = alert type (PORT_SCAN, BRUTE_FORCE, EXFILTRATION, NEW_IP,
  #                   TOR_EXIT, ADULT_DOMAIN, TRACKER_DOMAIN, DATA_HOG,
  #                   MALWARE_DOMAIN, DNS_TUNNELING, BEACONING)
  # Value = list of src_ip addresses to suppress for that type
  PORT_SCAN: []          # e.g. [192.168.1.180]  — suppress port scan from your own machine
  BRUTE_FORCE: []        # e.g. [192.168.1.50]   — suppress brute force from a scanner
  TRACKER_DOMAIN: []     # e.g. [192.168.1.10]   — suppress tracker alerts from a specific device
  MALWARE_DOMAIN: []     # rarely needed — only suppress for confirmed false positives
  DNS_TUNNELING: []      # e.g. [192.168.1.10]   — suppress for known long-DNS apps (some VPNs)
  BEACONING: []          # e.g. [192.168.1.10]   — suppress for legit periodic clients (NTP, telemetry)

agent:
  # Autonomous decision loop. Phase 1 is dry-run only — the agent observes
  # recent events, queries the LLM for what it would do, and writes every
  # decision to /var/lib/netwatchm/agent_actions.db. NO state-changing
  # actions are taken yet (whitelist edits, scans, notifications come in
  # Phase 2 once dry-run behaviour has been reviewed).
  enabled: false                          # set true after ollama is reachable
  dry_run: true                           # Phase 1: never set this to false
  model: qwen3:14b                        # any tool-calling Ollama model
  ollama_base_url: http://127.0.0.1:11434
  interval_seconds: 300                   # 5 min between ticks
  timeout_seconds: 120                    # per LLM call (CPU inference is slow)
  temperature: 0.2
  context_hours_back: 4                   # how far back to pull events each tick
  context_max_events: 50
  context_prompt_char_cap: 16000          # cap on JSON-serialised context in prompt
  max_tool_hops: 4                        # max read-only tool round-trips per tick
